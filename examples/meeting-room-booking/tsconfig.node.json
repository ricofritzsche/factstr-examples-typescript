{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "composite": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "typeRoots": ["./node_modules/@types"]
  },
  "include": [
    "vite.config.ts",
    "src/app/board_defaults.ts",
    "src/app/create_store.ts",
    "src/app/recent_events.ts",
    "src/events/**/*.ts",
    "src/features/**/*.ts"
  ]
}
